# ─────────────────────────────────────────────────────────────────────────────
# PropReach AI — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# Groq API Key (FREE tier — get yours at https://console.groq.com)
# Used for AI-generated call scripts, SMS, and email outreach.
# Free tier: 14,400 requests/day — more than enough for solo investors.
GROQ_API_KEY=gsk_...

# PropStream credentials are stored in the app's database (via Settings page),
# NOT here. This keeps them editable from the UI without requiring a restart.

# Optional: Override the local database file path (default: ./data/propreach.db)
# DATABASE_PATH=./data/propreach.db
